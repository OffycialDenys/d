# Copy this file to .env and fill in real values for production.
# Render / Railway inject these automatically; local XAMPP uses the
# defaults baked into includes/config/app.php when these are absent.

# Set to "true" ONLY after the service layer is migrated to MySQL and tested.
DB_ENABLED=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=investment_platform
DB_USER=root
DB_PASSWORD=
